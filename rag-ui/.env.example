# ── 必填 ──
DASHSCOPE_API_KEY=your_api_key_here

# ── 可选（有默认值）──
EMBEDDING_MODEL=text-embedding-v4
LLM_MODEL=qwen-max
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5

# Agent 配置
ENABLE_QUERY_REWRITE=false
ENABLE_WEB_FALLBACK=false
WEB_SEARCH_PROVIDER=bocha
BOCHA_API_KEY=
TAVILY_API_KEY=

# 前端访问端口（默认 3000）
PORT=3000
