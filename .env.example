# ==============================
# DashScope (阿里云百炼) 配置
# ==============================
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ==============================
# 模型配置
# ==============================
# 嵌入模型
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=2048

# 大语言模型
LLM_MODEL=qwen-max
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ==============================
# 文档切分配置
# ==============================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# 切分策略：recursive（递归，默认）/ semantic（语义）/ hierarchical（层次）
CHUNK_STRATEGY=recursive

# ==============================
# 向量库配置
# ==============================
FAISS_INDEX_PATH=data/vectorstore/faiss_index

# ==============================
# FastAPI 服务配置
# ==============================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# ==============================
# 检索配置
# ==============================
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.5
# 是否启用查询改写（检索前用 LLM 优化问题，提升命中率）：true / false
ENABLE_QUERY_REWRITE=false

# ==============================
# Agent：RAG + 网络兜底
# ==============================
# 搜索引擎：bocha（博查，国内直连，推荐）/ tavily（需代理）
WEB_SEARCH_PROVIDER=bocha
# 博查 Bocha 搜索 API Key（https://open.bochaai.com 申请，形如 sk-xxx）
BOCHA_API_KEY=sk-your_bocha_key_here
# Tavily 搜索 API Key（用 tavily 时才需要）
TAVILY_API_KEY=tvly-your_key_here
# 是否启用网络兜底（RAG 检索不足时转网络）：true / false
ENABLE_WEB_FALLBACK=false
# 高置信度阈值：≥ 此值直接用 RAG
FALLBACK_HIGH_THRESHOLD=0.65
# 低置信度阈值：≤ 此值直接转网络
FALLBACK_LOW_THRESHOLD=0.45
# 网络搜索返回结果数
WEB_SEARCH_MAX_RESULTS=5

# ==============================
# 日志配置
# ==============================
LOG_LEVEL=INFO
